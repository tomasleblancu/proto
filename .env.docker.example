# ── Proto All-in-One Deploy ─────────────────────────────────────────
# Copy this file to .env.docker and fill in the values.
# Used by: docker-compose.yml and Railway

# App name (selects which example app to deploy)
APP_NAME=minimal

# ── Gateway ────────────────────────────────────────────────────────
PORT=8092
INTERNAL_API_SECRET=your-secret-here

# Claude Code
CLAUDE_SETUP_TOKEN=your-setup-token
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TURNS=60
CLAUDE_TIMEOUT=300

# ── Supabase ───────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ── Frontend (baked into Vite bundle at build time) ────────────────
# VITE_GATEWAY_URL: leave empty for all-in-one deploy (auto-detects same origin)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# VITE_GATEWAY_URL=
# VITE_INTERNAL_SECRET=
