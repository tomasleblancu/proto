{
  "name": "@tleblancureta/proto",
  "version": "0.14.11",
  "type": "module",
  "description": "TypeScript framework for building AI-agent-driven apps. Define tools, widgets, and data models — get chat, Shell dashboard, auth, MCP server, and Claude CLI integration.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomasleblancu/proto.git",
    "directory": "packages/proto"
  },
  "exports": {
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "default": "./dist/mcp.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "default": "./dist/web.js"
    },
    "./shared": {
      "types": "./dist/shared.d.ts",
      "default": "./dist/shared.js"
    },
    "./gateway": {
      "types": "./dist/gateway.d.ts",
      "default": "./dist/gateway.js"
    }
  },
  "bin": {
    "proto-sync": "./bin/sync.mjs"
  },
  "files": [
    "dist/",
    "core-web/src/",
    "skills/",
    "migrations/",
    "defaults/",
    "bin/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
