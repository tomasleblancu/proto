# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Anthropic (for Claude CLI in gateway)
ANTHROPIC_API_KEY=your-anthropic-key

# Gateway
INTERNAL_API_SECRET=change-this-to-a-random-string
PORT=8092

# MCP
MCP_PORT=8093

# Frontend (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_GATEWAY_URL=http://localhost:8092
VITE_INTERNAL_SECRET=change-this-to-a-random-string

# Mail (optional)
# MAIL_SMTP_HOST=smtp.example.com
# MAIL_SMTP_USER=user@example.com
# MAIL_SMTP_PASS=password
# MAIL_SMTP_FROM="App Name <user@example.com>"
