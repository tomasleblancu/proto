# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Claude Code auth (get token from: claude setup-token)
CLAUDE_SETUP_TOKEN=your-setup-token

# Gateway
INTERNAL_API_SECRET=change-this-to-a-random-string
PORT=8092

# MCP
MCP_PORT=8093

# Frontend (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_GATEWAY_URL=http://localhost:8092
VITE_INTERNAL_SECRET=change-this-to-a-random-string

# Mail (optional)
# MAIL_SMTP_HOST=smtp.example.com
# MAIL_SMTP_USER=user@example.com
# MAIL_SMTP_PASS=password
# MAIL_SMTP_FROM="App Name <user@example.com>"

# Gmail OAuth (optional) — per-user inbox access for the agent.
# Enables the Gmail widget + gmail_* MCP tools (gmail_status, read_emails,
# send_email, search_emails). Create a Google Cloud OAuth client (Web app)
# with redirect URI pointing to your frontend's /gmail/callback route.
# GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=your-client-secret
# GMAIL_REDIRECT_URI=http://localhost:3002/gmail/callback
