{
  "name": "@proto-app/minimal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n gw,mcp,web -c blue,green,yellow \"tsx watch --env-file=.env app/gateway.ts\" \"tsx watch --env-file=.env app/mcp-http.ts\" \"cd web && npm run dev\"",
    "mcp": "tsx --env-file=.env app/mcp.ts",
    "mcp:http": "tsx --env-file=.env app/mcp-http.ts",
    "gateway": "tsx --env-file=.env app/gateway.ts",
    "dev:gateway": "tsx watch --env-file=.env app/gateway.ts",
    "postinstall": "proto-sync"
  },
  "dependencies": {
    "@tleblancureta/proto": "^0.6.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@supabase/supabase-js": "^2.49.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
