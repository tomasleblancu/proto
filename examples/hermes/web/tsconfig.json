{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@app/*": ["../app/*"],
      "@tleblancureta/proto/web": ["../../../packages/proto/core-web/src"],
      "@tleblancureta/proto/web/*": ["../../../packages/proto/core-web/src/*"],
      "@tleblancureta/proto/shared": ["../../../packages/proto/core-shared/src"],
      "@tleblancureta/proto/shared/*": ["../../../packages/proto/core-shared/src/*"]
    }
  },
  "include": ["src"]
}
