{
  "name": "proto-monorepo",
  "private": true,
  "workspaces": [
    "packages/proto",
    "packages/core-gateway",
    "packages/create-proto-app",
    "examples/*",
    "examples/*/web"
  ],
  "scripts": {
    "dev:gateway": "PROTO_APP_ROOT=examples/hermes npm run dev -w packages/core-gateway",
    "dev:web": "npm run dev -w @proto-app/hermes-web",
    "dev:minimal-web": "npm run dev -w @proto-app/minimal-web",
    "build": "npm run build -w packages/proto && npm run build -w packages/core-gateway && npm run build -w @proto-app/hermes-web && npm run build -w @proto-app/minimal-web",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
