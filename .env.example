# ── Gateway (Railway) ──────────────────────────────────────────────
PORT=8090
INTERNAL_API_SECRET=your-secret-here
DATA_DIR=/data

# Claude Code
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TURNS=60
CLAUDE_TIMEOUT=300

# MCP Server path (inside container)
MCP_SERVER_PATH=/app/packages/mcp/src/server.ts

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Gmail OAuth (Google Cloud Console)
GMAIL_CLIENT_ID=your-client-id
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REDIRECT_URI=https://your-web-domain.vercel.app/gmail/callback

# WhatsApp (Kapso)
KAPSO_API_URL=https://api.kapso.dev
KAPSO_API_KEY=your-kapso-key

# ZenRows (web scraping for sourcing)
ZENROWS_API_KEY=your-zenrows-key

# Hermes system mail — outbound notifications from scheduled tasks.
# Shared identity across all clients. Distinct from the user's personal
# Gmail (which is stored per-user in gmail_tokens via OAuth).
HERMES_SMTP_HOST=smtp.gmail.com
HERMES_SMTP_PORT=587
HERMES_SMTP_USER=hermes@yourdomain.com
HERMES_SMTP_PASS=your-app-password
HERMES_SMTP_FROM=Hermes <hermes@yourdomain.com>
HERMES_SMTP_REPLY_TO=hermes@yourdomain.com

# Hermes system mail — inbound (IMAP poller). Activates the mail-as-chat
# channel: users reply to Hermes mails and the agent processes the reply.
# By default reuses the SMTP user/pass (same mailbox). Unset HERMES_IMAP_HOST
# to disable inbound entirely.
HERMES_IMAP_HOST=imap.gmail.com
HERMES_IMAP_PORT=993
# HERMES_IMAP_USER=   # defaults to HERMES_SMTP_USER
# HERMES_IMAP_PASS=   # defaults to HERMES_SMTP_PASS
HERMES_IMAP_POLL_MS=30000

# ── Web (Vercel) ──────────────────────────────────────────────────
# Set these as Environment Variables in Vercel dashboard:
# VITE_GATEWAY_URL=https://your-railway-app.up.railway.app
# VITE_INTERNAL_SECRET=same-as-INTERNAL_API_SECRET
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
